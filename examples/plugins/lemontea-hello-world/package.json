{
  "name": "lemontea-hello-world",
  "version": "1.0.0",
  "displayName": "Hello World",
  "description": "示例插件：提供随机笑话工具、消息统计 Hook 和问候 Agent",
  "main": "dist/extension.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.4.0"
  },
  "lemontea": {
    "engine": ">=0.1.0",
    "activationEvents": [
      "onStartup"
    ],
    "contributes": {
      "tools": [
        {
          "id": "random-joke",
          "name": "Random Joke",
          "description": "随机讲一个笑话",
          "parameters": {
            "type": "object",
            "properties": {
              "language": {
                "type": "string",
                "description": "笑话语言: zh 或 en",
                "enum": [
                  "zh",
                  "en"
                ]
              }
            }
          }
        },
        {
          "id": "dice-roll",
          "name": "Dice Roll",
          "description": "掷骰子，返回随机数",
          "parameters": {
            "type": "object",
            "properties": {
              "sides": {
                "type": "number",
                "description": "骰子面数，默认6"
              },
              "count": {
                "type": "number",
                "description": "掷几次，默认1"
              }
            }
          }
        }
      ],
      "agents": [
        {
          "id": "greeting-agent",
          "name": "Greeting Agent",
          "description": "一个友好的问候 Agent，擅长用幽默的方式打招呼"
        }
      ],
      "views": {
        "sidebar": [],
        "chatCard": [],
        "settings": [],
        "page": []
      },
      "hooks": {
        "onBeforeChat": true,
        "onAfterChat": true
      }
    }
  }
}
