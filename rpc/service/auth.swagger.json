{
  "swagger": "2.0",
  "info": {
    "title": "rpc/service/auth.proto",
    "version": "version not set"
  },
  "tags": [
    {
      "name": "Auth"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/auth/check-availability": {
      "post": {
        "summary": "CheckFieldAvailability 检查用户名或邮箱是否被使用",
        "operationId": "Auth_CheckFieldAvailability",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/serverCheckFieldAvailabilityResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/serverCheckFieldAvailabilityRequest"
            }
          }
        ],
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/auth/login": {
      "post": {
        "summary": "Login 登录",
        "operationId": "Auth_Login",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/serverLoginResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/serverLoginRequest"
            }
          }
        ],
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/auth/logout": {
      "post": {
        "summary": "Logout 登出",
        "operationId": "Auth_Logout",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/commonEmpty"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "description": "可以为空，通过认证头获取用户信息",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/serverLogoutRequest"
            }
          }
        ],
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/auth/register": {
      "post": {
        "summary": "Register 注册",
        "operationId": "Auth_Register",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/commonEmpty"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/serverRegisterRequest"
            }
          }
        ],
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/auth/reset-password": {
      "post": {
        "summary": "ResetPassword 忘记密码",
        "operationId": "Auth_ResetPassword",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/commonEmpty"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/serverResetPasswordRequest"
            }
          }
        ],
        "tags": [
          "Auth"
        ]
      }
    },
    "/v1/auth/send-email-code": {
      "post": {
        "summary": "SendEmailVerificationCode 发送邮件验证码",
        "operationId": "Auth_SendEmailVerificationCode",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/commonEmpty"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/serverSendEmailVerificationCodeRequest"
            }
          }
        ],
        "tags": [
          "Auth"
        ]
      }
    }
  },
  "definitions": {
    "commonEmpty": {
      "type": "object",
      "title": "Empty 空参数占位"
    },
    "commonVerificationCodeType": {
      "type": "string",
      "enum": [
        "VERIFICATION_CODE_TYPE_UNSPECIFIED",
        "VERIFICATION_CODE_TYPE_REGISTER",
        "VERIFICATION_CODE_TYPE_RESET_PASSWORD"
      ],
      "default": "VERIFICATION_CODE_TYPE_UNSPECIFIED"
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "serverCheckFieldAvailabilityRequest": {
      "type": "object",
      "properties": {
        "fieldType": {
          "$ref": "#/definitions/serverFieldType",
          "title": "字段类型"
        },
        "value": {
          "type": "string",
          "title": "字段值"
        }
      },
      "title": "CheckFieldAvailabilityRequest 检查字段可用性请求"
    },
    "serverCheckFieldAvailabilityResponse": {
      "type": "object",
      "properties": {
        "available": {
          "type": "boolean",
          "title": "是否可用"
        }
      },
      "title": "CheckFieldAvailabilityResponse 检查字段可用性返回"
    },
    "serverFieldType": {
      "type": "string",
      "enum": [
        "FIELD_TYPE_UNSPECIFIED",
        "FIELD_TYPE_USERNAME",
        "FIELD_TYPE_EMAIL"
      ],
      "default": "FIELD_TYPE_UNSPECIFIED",
      "title": "FieldType 字段类型枚举"
    },
    "serverLoginRequest": {
      "type": "object",
      "properties": {
        "loginField": {
          "type": "string",
          "title": "登录字段（用户名或邮箱）"
        },
        "passwordMd5": {
          "type": "string",
          "title": "密码MD5"
        }
      },
      "title": "LoginRequest 登录请求"
    },
    "serverLoginResponse": {
      "type": "object",
      "properties": {
        "accessToken": {
          "type": "string",
          "title": "访问令牌"
        },
        "expiresIn": {
          "type": "string",
          "format": "int64",
          "title": "令牌过期时间（秒）"
        },
        "userInfo": {
          "$ref": "#/definitions/serverUserInfo",
          "title": "用户信息"
        }
      },
      "title": "LoginResponse 登录返回"
    },
    "serverLogoutRequest": {
      "type": "object",
      "description": "可以为空，通过认证头获取用户信息",
      "title": "LogoutRequest 登出请求"
    },
    "serverRegisterRequest": {
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "title": "用户名"
        },
        "passwordMd5": {
          "type": "string",
          "title": "密码MD5"
        },
        "email": {
          "type": "string",
          "title": "邮箱"
        },
        "emailVerificationCode": {
          "type": "string",
          "format": "int64",
          "title": "邮箱验证码"
        }
      },
      "title": "RegisterRequest 注册请求"
    },
    "serverResetPasswordRequest": {
      "type": "object",
      "properties": {
        "loginField": {
          "type": "string",
          "title": "登录字段（用户名或邮箱）"
        },
        "emailVerificationCode": {
          "type": "string",
          "title": "邮箱验证码"
        },
        "newPasswordMd5": {
          "type": "string",
          "title": "新密码MD5"
        }
      },
      "title": "ResetPasswordRequest 重置密码请求"
    },
    "serverSendEmailVerificationCodeRequest": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "title": "邮箱地址"
        },
        "username": {
          "type": "string"
        },
        "codeType": {
          "$ref": "#/definitions/commonVerificationCodeType"
        }
      },
      "title": "SendEmailVerificationCodeRequest 发送邮件验证码请求"
    },
    "serverUserInfo": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "format": "int64",
          "title": "用户ID"
        },
        "username": {
          "type": "string",
          "title": "用户名"
        },
        "email": {
          "type": "string",
          "title": "邮箱"
        },
        "createdAt": {
          "type": "string",
          "format": "int64",
          "title": "创建时间（Unix时间戳）"
        },
        "updatedAt": {
          "type": "string",
          "format": "int64",
          "title": "更新时间（Unix时间戳）"
        }
      },
      "title": "UserInfo 用户信息"
    }
  }
}
