{
  "swagger": "2.0",
  "info": {
    "title": "rpc/service/chat.proto",
    "version": "version not set"
  },
  "tags": [
    {
      "name": "Chat"
    }
  ],
  "consumes": [
    "application/json"
  ],
  "produces": [
    "application/json"
  ],
  "paths": {
    "/v1/chat/completions": {
      "post": {
        "summary": "流式 Chat Completions（等价于 OpenAI /v1/chat/completions + stream）",
        "operationId": "Chat_Completions",
        "responses": {
          "200": {
            "description": "A successful response.(streaming responses)",
            "schema": {
              "type": "object",
              "properties": {
                "result": {
                  "$ref": "#/definitions/serverCompletionsResponse"
                },
                "error": {
                  "$ref": "#/definitions/rpcStatus"
                }
              },
              "title": "Stream result of serverCompletionsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/serverCompletionsRequest"
            }
          }
        ],
        "tags": [
          "Chat"
        ]
      }
    },
    "/v1/chats/delete/{chatUuid}": {
      "post": {
        "summary": "删除对话",
        "operationId": "Chat_DeleteChat",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/commonEmpty"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "chatUuid",
            "description": "要删除的对话 ID",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ChatDeleteChatBody"
            }
          }
        ],
        "tags": [
          "Chat"
        ]
      }
    },
    "/v1/chats/get": {
      "post": {
        "summary": "获取历史对话记录列表",
        "operationId": "Chat_ListChats",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/serverListChatsResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/serverListChatsRequest"
            }
          }
        ],
        "tags": [
          "Chat"
        ]
      }
    },
    "/v1/chats/messages/delete/{chatUuid}/{messageId}": {
      "post": {
        "summary": "删除对话消息",
        "operationId": "Chat_DeleteChatMessage",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/serverDeleteChatMessageResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "chatUuid",
            "description": "对话 ID",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "messageId",
            "description": "要删除的消息 ID",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ChatDeleteChatMessageBody"
            }
          }
        ],
        "tags": [
          "Chat"
        ]
      }
    },
    "/v1/chats/messages/get/{chatUuid}": {
      "post": {
        "summary": "获取对话消息",
        "operationId": "Chat_GetChatMessages",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/serverGetChatMessagesResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "chatUuid",
            "description": "对话 ID",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ChatGetChatMessagesBody"
            }
          }
        ],
        "tags": [
          "Chat"
        ]
      }
    },
    "/v1/chats/title/save/{chatUuid}/{chatTitle}": {
      "post": {
        "summary": "保存对话标题",
        "operationId": "Chat_ChatTitleSave",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/commonEmpty"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "chatUuid",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "chatTitle",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ChatChatTitleSaveBody"
            }
          }
        ],
        "tags": [
          "Chat"
        ]
      }
    },
    "/v1/chats/title/{chatUuid}": {
      "post": {
        "summary": "获取对话标题",
        "operationId": "Chat_ChatTitle",
        "responses": {
          "200": {
            "description": "A successful response.",
            "schema": {
              "$ref": "#/definitions/serverChatTitleResponse"
            }
          },
          "default": {
            "description": "An unexpected error response.",
            "schema": {
              "$ref": "#/definitions/rpcStatus"
            }
          }
        },
        "parameters": [
          {
            "name": "chatUuid",
            "in": "path",
            "required": true,
            "type": "string"
          },
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": {
              "$ref": "#/definitions/ChatChatTitleBody"
            }
          }
        ],
        "tags": [
          "Chat"
        ]
      }
    }
  },
  "definitions": {
    "ChatChatTitleBody": {
      "type": "object",
      "title": "ChatTitleRequest 获取对话标题请求"
    },
    "ChatChatTitleSaveBody": {
      "type": "object",
      "title": "ChatTitleSaveRequest 保存对话标题请求"
    },
    "ChatDeleteChatBody": {
      "type": "object",
      "title": "DeleteChatRequest 删除对话请求"
    },
    "ChatDeleteChatMessageBody": {
      "type": "object",
      "title": "DeleteChatMessageRequest 删除对话消息请求"
    },
    "ChatGetChatMessagesBody": {
      "type": "object",
      "properties": {
        "offset": {
          "type": "string",
          "format": "int64"
        },
        "limit": {
          "type": "string",
          "format": "int64"
        }
      },
      "title": "GetChatMessagesRequest 获取对话消息请求"
    },
    "commonChatInfo": {
      "type": "object",
      "properties": {
        "chatUuid": {
          "type": "string",
          "title": "对话 ID"
        },
        "title": {
          "type": "string",
          "title": "对话标题"
        },
        "modelId": {
          "type": "string",
          "format": "int64",
          "title": "使用的模型"
        },
        "createdAt": {
          "type": "string",
          "format": "int64",
          "title": "创建时间（unix 秒）"
        },
        "updatedAt": {
          "type": "string",
          "format": "int64",
          "title": "更新时间（unix 秒）"
        },
        "messageCount": {
          "type": "integer",
          "format": "int32",
          "title": "消息数量"
        },
        "lastMessagePreview": {
          "type": "string",
          "title": "最后一条消息预览"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "title": "元数据"
        }
      },
      "title": "ChatInfo 对话信息"
    },
    "commonChatMessageAudioURL": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "title": "URL 可以是传统 URL 或符合 RFC-2397 的特殊 URL"
        },
        "uri": {
          "type": "string"
        },
        "mimeType": {
          "type": "string",
          "title": "MIMEType 是音频的 MIME 类型"
        },
        "extra": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "title": "Extra 用于存储音频 URL 的额外信息"
        }
      },
      "title": "ChatMessageAudioURL 表示聊天消息中的音频部分"
    },
    "commonChatMessageFileURL": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "title": "文件 URL"
        },
        "uri": {
          "type": "string"
        },
        "mimeType": {
          "type": "string",
          "title": "MIMEType 是文件的 MIME 类型"
        },
        "name": {
          "type": "string",
          "title": "Name 是文件名称"
        },
        "extra": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "title": "Extra 用于存储文件 URL 的额外信息"
        }
      },
      "title": "ChatMessageFileURL 表示聊天消息中的文件部分"
    },
    "commonChatMessageImageURL": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "title": "URL 可以是传统 URL 或符合 RFC-2397 的特殊 URL（如 data URL）"
        },
        "uri": {
          "type": "string"
        },
        "detail": {
          "$ref": "#/definitions/commonImageURLDetail",
          "title": "Detail 是图像 URL 的质量等级"
        },
        "mimeType": {
          "type": "string",
          "title": "MIMEType 是图像的 MIME 类型"
        },
        "extra": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "title": "Extra 用于存储图像 URL 的额外信息"
        }
      },
      "title": "ChatMessageImageURL 表示聊天消息中的图像部分"
    },
    "commonChatMessagePart": {
      "type": "object",
      "properties": {
        "type": {
          "$ref": "#/definitions/commonChatMessagePartType",
          "title": "Type 是片段的类型"
        },
        "text": {
          "type": "string",
          "title": "Text 是文本内容，当 Type 为 \"text\" 时使用"
        },
        "imageUrl": {
          "$ref": "#/definitions/commonChatMessageImageURL",
          "title": "ImageURL 是图像链接内容，当 Type 为 \"image_url\" 时使用"
        },
        "audioUrl": {
          "$ref": "#/definitions/commonChatMessageAudioURL",
          "title": "AudioURL 是音频链接内容，当 Type 为 \"audio_url\" 时使用"
        },
        "videoUrl": {
          "$ref": "#/definitions/commonChatMessageVideoURL",
          "title": "VideoURL 是视频链接内容，当 Type 为 \"video_url\" 时使用"
        },
        "fileUrl": {
          "$ref": "#/definitions/commonChatMessageFileURL",
          "title": "FileURL 是文件链接内容，当 Type 为 \"file_url\" 时使用"
        }
      },
      "title": "ChatMessagePart 是聊天消息中的内容片段"
    },
    "commonChatMessagePartType": {
      "type": "string",
      "enum": [
        "CHAT_MESSAGE_PART_TYPE_UNSPECIFIED",
        "CHAT_MESSAGE_PART_TYPE_TEXT",
        "CHAT_MESSAGE_PART_TYPE_IMAGE_URL",
        "CHAT_MESSAGE_PART_TYPE_AUDIO_URL",
        "CHAT_MESSAGE_PART_TYPE_VIDEO_URL",
        "CHAT_MESSAGE_PART_TYPE_FILE_URL"
      ],
      "default": "CHAT_MESSAGE_PART_TYPE_UNSPECIFIED",
      "description": "- CHAT_MESSAGE_PART_TYPE_UNSPECIFIED: 未指定\n - CHAT_MESSAGE_PART_TYPE_TEXT: 文本\n - CHAT_MESSAGE_PART_TYPE_IMAGE_URL: 图像链接\n - CHAT_MESSAGE_PART_TYPE_AUDIO_URL: 音频链接\n - CHAT_MESSAGE_PART_TYPE_VIDEO_URL: 视频链接\n - CHAT_MESSAGE_PART_TYPE_FILE_URL: 文件链接",
      "title": "ChatMessagePartType 是聊天消息中内容片段的类型"
    },
    "commonChatMessageVideoURL": {
      "type": "object",
      "properties": {
        "url": {
          "type": "string",
          "title": "URL 可以是传统 URL 或符合 RFC-2397 的特殊 URL"
        },
        "uri": {
          "type": "string"
        },
        "mimeType": {
          "type": "string",
          "title": "MIMEType 是视频的 MIME 类型"
        },
        "extra": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "title": "Extra 用于存储视频 URL 的额外信息"
        }
      },
      "title": "ChatMessageVideoURL 表示聊天消息中的视频部分"
    },
    "commonEmpty": {
      "type": "object",
      "title": "Empty 空参数占位"
    },
    "commonFunctionCall": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "title": "Name 是要调用的函数名称"
        },
        "arguments": {
          "type": "string",
          "title": "Arguments 是调用函数所需的参数，以 JSON 格式表示"
        }
      },
      "title": "FunctionCall 是消息中的函数调用信息"
    },
    "commonImageURLDetail": {
      "type": "string",
      "enum": [
        "IMAGE_URL_DETAIL_UNSPECIFIED",
        "IMAGE_URL_DETAIL_HIGH",
        "IMAGE_URL_DETAIL_LOW",
        "IMAGE_URL_DETAIL_AUTO"
      ],
      "default": "IMAGE_URL_DETAIL_UNSPECIFIED",
      "description": "- IMAGE_URL_DETAIL_UNSPECIFIED: 未指定\n - IMAGE_URL_DETAIL_HIGH: 高质量\n - IMAGE_URL_DETAIL_LOW: 低质量\n - IMAGE_URL_DETAIL_AUTO: 自动选择",
      "title": "ImageURLDetail 是图像 URL 的细节级别"
    },
    "commonLogProb": {
      "type": "object",
      "properties": {
        "token": {
          "type": "string",
          "title": "Token 表示 token 的文本内容"
        },
        "logProb": {
          "type": "number",
          "format": "double",
          "title": "LogProb 是该 token 的对数概率"
        },
        "bytes": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "int64"
          },
          "title": "Bytes 是该 token 的 UTF-8 字节表示（整数列表）"
        },
        "topLogProbs": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/commonTopLogProb"
          },
          "title": "TopLogProbs 是最可能的若干 token 及其对数概率列表"
        }
      },
      "title": "LogProb 表示一个 token 的概率信息"
    },
    "commonLogProbs": {
      "type": "object",
      "properties": {
        "content": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/commonLogProb"
          },
          "title": "Content 是包含对数概率信息的消息内容 token 列表"
        }
      },
      "title": "LogProbs 是包含 token 概率信息的顶层结构"
    },
    "commonMessage": {
      "type": "object",
      "properties": {
        "content": {
          "type": "string",
          "description": "主要内容（纯文本）",
          "title": "通用字段（所有消息类型都可能包含）"
        },
        "multiContent": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/commonChatMessagePart"
          },
          "title": "多模态内容（如图片、文本、文件等）"
        },
        "name": {
          "type": "string",
          "title": "消息发送者名称（可选）"
        },
        "extra": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "title": "扩展信息（可选）"
        },
        "role": {
          "type": "string"
        },
        "systemContent": {
          "type": "string",
          "description": "系统指令内容（原 SystemMessage.content）",
          "title": "系统消息相关字段（仅在 role == SYSTEM 时使用）"
        },
        "toolCalls": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/commonToolCall"
          },
          "description": "工具调用请求",
          "title": "助手消息相关字段（仅在 role == ASSISTANT 时使用）"
        },
        "responseMeta": {
          "$ref": "#/definitions/commonResponseMeta",
          "title": "响应元信息"
        },
        "reasoningContent": {
          "type": "string",
          "title": "推理过程（如思维链）"
        },
        "toolCallId": {
          "type": "string",
          "description": "工具调用 ID",
          "title": "工具消息相关字段（仅在 role == TOOL 时使用）"
        },
        "toolName": {
          "type": "string",
          "title": "工具名称"
        },
        "chatUuid": {
          "type": "string",
          "title": "以下为业务字段"
        }
      },
      "title": "Message 表示一条聊天消息，使用 oneof 分离不同角色的消息类型"
    },
    "commonResponseMeta": {
      "type": "object",
      "properties": {
        "finishReason": {
          "type": "string",
          "title": "FinishReason 是聊天响应结束的原因"
        },
        "usage": {
          "$ref": "#/definitions/commonTokenUsage",
          "title": "Usage 是聊天响应的 token 使用情况"
        },
        "logProbs": {
          "$ref": "#/definitions/commonLogProbs",
          "title": "LogProbs 是对数概率信息"
        }
      },
      "title": "ResponseMeta 收集聊天响应的元信息"
    },
    "commonTokenUsage": {
      "type": "object",
      "properties": {
        "promptTokens": {
          "type": "integer",
          "format": "int32",
          "title": "PromptTokens 是提示词中的 token 数量"
        },
        "completionTokens": {
          "type": "integer",
          "format": "int32",
          "title": "CompletionTokens 是生成内容中的 token 数量"
        },
        "totalTokens": {
          "type": "integer",
          "format": "int32",
          "title": "TotalTokens 是请求中总的 token 数量"
        }
      },
      "title": "TokenUsage 表示聊天模型请求的 token 使用情况"
    },
    "commonToolCall": {
      "type": "object",
      "properties": {
        "index": {
          "type": "integer",
          "format": "int32",
          "title": "Index 在一条消息包含多个工具调用时使用"
        },
        "id": {
          "type": "string",
          "title": "ID 是工具调用的唯一标识"
        },
        "type": {
          "type": "string",
          "title": "Type 是工具调用的类型"
        },
        "function": {
          "$ref": "#/definitions/commonFunctionCall",
          "title": "Function 是具体的函数调用内容"
        },
        "extra": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          },
          "title": "Extra 用于存储工具调用的额外信息"
        }
      },
      "title": "ToolCall 是消息中的工具调用信息"
    },
    "commonTopLogProb": {
      "type": "object",
      "properties": {
        "token": {
          "type": "string",
          "title": "Token 表示 token 的文本内容"
        },
        "logProb": {
          "type": "number",
          "format": "double",
          "title": "LogProb 是该 token 的对数概率"
        },
        "bytes": {
          "type": "array",
          "items": {
            "type": "string",
            "format": "int64"
          },
          "title": "Bytes 是该 token 的 UTF-8 字节表示（整数列表）"
        }
      },
      "title": "TopLogProb 表示某个 token 的最高对数概率信息"
    },
    "protobufAny": {
      "type": "object",
      "properties": {
        "@type": {
          "type": "string"
        }
      },
      "additionalProperties": {}
    },
    "rpcStatus": {
      "type": "object",
      "properties": {
        "code": {
          "type": "integer",
          "format": "int32"
        },
        "message": {
          "type": "string"
        },
        "details": {
          "type": "array",
          "items": {
            "type": "object",
            "$ref": "#/definitions/protobufAny"
          }
        }
      }
    },
    "serverChatCompletionChoice": {
      "type": "object",
      "properties": {
        "index": {
          "type": "integer",
          "format": "int32",
          "title": "选择索引"
        },
        "delta": {
          "$ref": "#/definitions/commonMessage",
          "title": "生成的消息"
        },
        "logprobs": {
          "$ref": "#/definitions/commonLogProbs",
          "title": "对数概率信息"
        },
        "finishReason": {
          "type": "string",
          "title": "结束原因：\"stop\", \"length\", \"tool_calls\", \"content_filter\", \"function_call\""
        }
      },
      "title": "ChatCompletionChoice 聊天完成选择"
    },
    "serverChatCompletionFunction": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "title": "函数名称"
        },
        "description": {
          "type": "string",
          "title": "函数描述"
        },
        "parameters": {
          "type": "string",
          "title": "JSON Schema格式的参数定义"
        }
      },
