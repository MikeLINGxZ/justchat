<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="lemontea-desktop"
        Arguments=""
        InstallLocation="C:\Program Files\LemonteaDesktop\LemonteaDesktop">
    </Installer>
    <PackageInformation
        PackageName="Lemontea Desktop"
        PackageDisplayName="Lemontea Desktop"
        PublisherName="CN=MikeLinGxZ"
        PublisherDisplayName="MikeLinGxZ"
        Version="0.1.0.0"
        PackageDescription="A lemontea-desktop application">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.example.rxintelligencecli"
                Description="A lemontea-desktop application"
                DisplayName="Lemontea Desktop"
                ExecutableName="lemontea-desktop"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Lemontea Desktop</DisplayName>
            <PublisherDisplayName>MikeLinGxZ</PublisherDisplayName>
            <Description>A lemontea-desktop application</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="lemontea-desktop.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
